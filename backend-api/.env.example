PORT=4000
NODE_ENV=development

# Supabase — Settings → API Keys:
#   SUPABASE_URL = Project URL (Connect modal or Data API)
#   SUPABASE_SERVICE_ROLE_KEY = Secret keys → default → reveal → copy
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=PASTE_YOUR_SECRET_KEY_HERE
SUPABASE_PUBLISHABLE_KEY=PASTE_YOUR_PUBLISHABLE_KEY_HERE

ADMIN_EMAIL=admin@gmail.com
ADMIN_PASSWORD=change-this-password
